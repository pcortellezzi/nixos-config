{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
"agents": {
  "sisyphus":      { "model": "opencode-go/kimi-k3" },
  "hephaestus":    { "model": "openai/gpt-5.6-sol", "variant": "medium" },
  "oracle":        { "model": "openai/gpt-5.6-sol", "variant": "high" },
  "momus":         { "model": "openai/gpt-5.6-terra", "variant": "high" },
  "metis":         { "model": "opencode-go/kimi-k3" },
  "prometheus":    { "model": "opencode-go/glm-5.2" },
  "atlas":         { "model": "opencode-go/kimi-k3" },
  "explore":       { "model": "opencode-go/deepseek-v4-flash" },
  "librarian":     { "model": "opencode-go/deepseek-v4-flash" },
  "quick":         { "model": "opencode-go/deepseek-v4-flash" },
  "caveman":       { "model": "opencode-go/deepseek-v4-flash" },
  "sisyphus-junior": { "model": "opencode-go/deepseek-v4-flash" },
  "multimodal-looker": { "model": "opencode-go/deepseek-v4-flash" },
  "speckit":       { "model": "opencode-go/deepseek-v4-flash" }
},
"categories": {
  "ultrabrain":        { "model": "openai/gpt-5.6-sol", "variant": "xhigh" },
  "deep":              { "model": "opencode-go/kimi-k3" },
  "unspecified-high":  { "model": "opencode-go/kimi-k3" },
  "unspecified-low":   { "model": "opencode-go/deepseek-v4-flash" },
  "visual-engineering": { "model": "opencode-go/qwen3.6-plus" },
  "writing":           { "model": "opencode-go/deepseek-v4-flash" },
  "artistry":          { "model": "opencode-go/deepseek-v4-flash" },
  "quick":             { "model": "opencode-go/deepseek-v4-flash" }
},
  "google_auth": false,
  "team_mode": {
    "enabled": true,
    "max_parallel_members": 8,
    "tmux_visualization": true
  },
  "agent_order": ["sisyphus", "hephaestus", "prometheus", "atlas"],
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "hashline_edit": true,
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 30,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },
  "background_task": {
    "defaultConcurrency": 8,
    "staleTimeoutMs": 180000,
    "providerConcurrency": {
      "opencode-go": 5,
      "anthropic": 3,
      "google": 5
    },
    "mcp": {
      "servers": {
        "pdf-reader": {
          "command": "npx",
          "args": ["-y", "@modelcontextprotocol/server-pdf"],
          "description": "Read and analyze PDF documents"
        },
        "google-drive": {
          "command": "npx",
          "args": ["-y", "@modelcontextprotocol/server-gdrive"],
          "description": "Access files in Google Drive"
        },
        "memory-plus": {
          "command": "npx",
          "args": ["-y", "@modelcontextprotocol/server-memory"],
          "description": "Advanced graph-based memory"
        },
        "codegraph": {
          "command": "codegraph",
          "args": ["serve", "--mcp"],
          "description": "Pre-indexed code knowledge graph — 92% fewer tool calls for code exploration"
        }
      }
    },
    "modelConcurrency": {
      "opencode-go/deepseek-v4-flash": 5
    }
  },
  "experimental": {
    "aggressive_truncation": true,
    "auto_resume": true,
    "task_system": true,
    "parallel_discovery": true,
    "streaming_tools": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": {
        "enabled": true,
        "turns": 10
      },
      "strategies": {
        "deduplication": {
          "enabled": true
        },
        "supersede_writes": {
          "enabled": true,
          "aggressive": false
        },
        "purge_errors": {
          "enabled": true,
          "turns": 5
        }
      }
    }
  }
}
